# Gemini / Google AI
GEMINI_API_KEY=your_gemini_api_key_here

# Google Earth Engine
GEE_PROJECT_ID=your_gcp_project_id
GEE_SERVICE_ACCOUNT=your_service_account@your_project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=path/to/service_account_key.json

# Feature flags
USE_GEE_CLIMATE=true
USE_GEE_TERRITORY=true
